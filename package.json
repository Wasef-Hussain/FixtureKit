{
  "name": "fixturekit",
  "version": "0.1.0",
  "description": "Paste a TypeScript interface or Zod schema → get fixture code",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "verify:v21": "npx tsx scripts/verify-v21.mjs",
    "verify:parser": "node scripts/verify-parser.cjs",
    "verify:zod": "node scripts/verify-zod.cjs",
    "verify:generator": "node scripts/verify-generator.cjs",
    "verify": "npm run verify:parser && npm run verify:zod && npm run verify:generator && npm run verify:v21"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "gif-encoder-2": "^1.0.5",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "puppeteer": "^25.1.0",
    "vite": "^5.3.4"
  }
}
